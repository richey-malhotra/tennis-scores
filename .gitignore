# ──────────────────────────────────────────────
#  Python
# ──────────────────────────────────────────────

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments — never commit dependencies
venv/
.venv/
env/

# ──────────────────────────────────────────────
#  Environment & secrets
# ──────────────────────────────────────────────

# dotenv files may contain API keys or credentials
.env
.env.*

# ──────────────────────────────────────────────
#  IDE / editor
# ──────────────────────────────────────────────

# VS Code workspace settings (personal, not project-wide)
.vscode/

# JetBrains (PyCharm, etc.)
.idea/

# macOS Finder metadata
.DS_Store

# ──────────────────────────────────────────────
#  Vercel
# ──────────────────────────────────────────────

# Local Vercel project config (generated by `vercel link`)
.vercel/

# ──────────────────────────────────────────────
#  Misc
# ──────────────────────────────────────────────

# Debug / exploration scripts created during development
debug*.py
find_api*.py
explore*.py
inspect_*.py

# Logs
*.log
